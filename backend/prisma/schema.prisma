generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model Lead {
  id String @id @default(cuid())

  name    String
  email   String
  company String?
  message String

  seriousnessScore Int?
  sentiment        String?
  urgency          String?
  roleType         String?

  analysis  Json?
  status    String   @default("new")
  createdAt DateTime @default(now())
}
